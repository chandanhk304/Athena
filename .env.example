# LLM Configuration
LLM_BACKEND=gemini # Acceptable values: 'gemini', 'ollama', 'groq'

# Gemini Cloud Settings (Required if LLM_BACKEND=gemini and for data gen)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq Cloud Settings (Required for massive fast data generation)
GROQ_API_KEY=your_groq_api_key_here

# Ollama Local Settings (Optional, required if LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Knowledge Graph (Neo4j Aura Free)
NEO4J_URI=neo4j+s://your_instance_id.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_aura_password_here

# Vector Store (Pinecone Free)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=athena-vectors

# Simulator Postgres Database (Neon Serverless Free)
# e.g. postgresql://user:password@ep-cool-name-123.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://your_db_user:your_db_pass@your_neon_host.aws.neon.tech/neondb?sslmode=require

# Simulator Configuration
SIMULATOR_API_URL=http://localhost:8000/api/v1
ATHENA_WEBHOOK_URL=http://localhost:8001/api/v1/webhook/event
